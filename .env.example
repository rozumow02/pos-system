# Root .env is for Docker Compose / Nginx deployment.
POSTGRES_DB=posdb
POSTGRES_USER=posuser
POSTGRES_PASSWORD=pospass
DATABASE_URL=postgres://posuser:pospass@postgres:5432/posdb?sslmode=disable
BACKEND_PORT=8080
LOG_LEVEL=info
FRONTEND_ORIGIN=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
LOW_STOCK_THRESHOLD=5
MIGRATIONS_PATH=/app/migrations
DB_CONNECT_RETRIES=20
NUXT_PUBLIC_API_BASE=/api
NUXT_API_SERVER_BASE=http://backend:8080/api
