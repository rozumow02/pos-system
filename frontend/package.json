{
  "name": "pos-system-frontend",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "nuxt prepare",
    "dev": "nuxt dev --no-fork --host 0.0.0.0 --port 3000",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check": "npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "nuxt": "4.1.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^9.36.0",
    "typescript": "^5.9.2",
    "vue-tsc": "^3.1.1"
  }
}
